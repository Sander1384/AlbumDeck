NAVIDROME_URL=https://music.example.com
NAVIDROME_USER=your_user
NAVIDROME_PASS=your_navidrome_credential
NAVIDROME_CLIENT=albumdeck-app
NAVIDROME_ALLOW_INSECURE_TLS=false
APP_PORT=8080
NAVIDROME_ALBUM_BATCH_SIZE=500
NAVIDROME_MAX_ALBUMS=20000

# Optional, but recommended for more reliable Discogs search/image lookup.
DISCOGS_TOKEN=

# Optional for frontend dev mode
VITE_API_BASE=http://localhost:8080/api
